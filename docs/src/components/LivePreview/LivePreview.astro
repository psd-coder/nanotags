---
import type { HTMLAttributes } from "astro/types";
import styles from "./styles.module.css";

type Props = HTMLAttributes<"div">

const { class: className, ...rest } = Astro.props;
---
<x-live-preview class:list={[styles.host, className]} {...rest}>
  <iframe data-ref="frame" class={styles.frame} sandbox="allow-scripts" title="Live preview" />
</x-live-preview>
<script>
  import "./components";
</script>
