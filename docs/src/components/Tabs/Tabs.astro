---
import type { HTMLAttributes } from "astro/types";
import styles from "./styles.module.css";

type Props = HTMLAttributes<"div"> & {
  active: string;
};

const { active, class: className, ...rest } = Astro.props;
---

<x-tabs class:list={[styles.tabs, className]} role="tablist" active={active} {...rest}>
  <slot />
</x-tabs>
<script>
  import { define, type TypedEvent } from "nano-wc";
  import { attachRovingFocus } from "../../attachments/attachRovingFocus";

  declare global {
    interface HTMLElementTagNameMap {
      "x-tabs": InstanceType<typeof XTabs>;
    }
    interface HTMLElementEventMap {
      change: TypedEvent<InstanceType<typeof XTabs>, { value: string }>;
    }
  }

  const XTabs = define("x-tabs")
    .withProps((p) => ({ active: p.string(null) }))
    .withRefs((r) => ({ tabs: r.many("button") }))
    .setup((ctx) => {
      const { $active } = ctx.props;

      const rover = attachRovingFocus(ctx, () => ctx.refs.tabs, {
        onActivate(item) {
          const value = item.dataset.value;
          if (value) {
            $active.set(value);
            ctx.emit("change", { value });
          }
        },
      });

      ctx.effect(ctx.props.$active, (value) => {
        if (!value) return;

        ctx.refs.tabs.forEach((t, i) => {
          const isActive = t.dataset.value === value;
          t.setAttribute("aria-selected", String(isActive));
          if (isActive) rover.setActive(i);
        });
      });

      return {
        get value() {
          return $active.get();
        },
        set value(val: string | null) {
          $active.set(val);
        },
      };
    });
</script>
