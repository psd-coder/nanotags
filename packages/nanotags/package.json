{
  "name": "nanotags",
  "version": "0.15.2",
  "description": "Tiny Custom Elements wrapper with nanostores reactivity. No Shadow DOM, typesafe builder, props/refs, automatic cleanup, all under 3 KB.",
  "keywords": [
    "astro",
    "custom-elements",
    "lightweight",
    "nanostores",
    "reactive",
    "typescript",
    "web-components"
  ],
  "license": "MIT",
  "author": "Pavel Grinchenko <psdcoder@gmail.com>",
  "repository": "psd-coder/nanotags",
  "files": [
    "dist/*",
    "package.json",
    "README.md",
    "LICENSE.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./render": {
      "types": "./dist/render.d.mts",
      "import": "./dist/render.mjs"
    },
    "./context": {
      "types": "./dist/context.d.mts",
      "import": "./dist/context.mjs"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "build:size": "tsdown --minify --out-dir .size-check --no-dts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "pnpm run /^typecheck:/",
    "typecheck:src": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "lint": "pnpm run /^lint:/",
    "lint:oxlint": "oxlint .",
    "lint:types": "pnpm run typecheck",
    "lint:size": "pnpm run build:size && size-limit",
    "format": "pnpm run /^format:/",
    "format:oxlint": "oxlint --fix --fix-suggestions .",
    "format:oxfmt": "oxfmt src/",
    "format:check": "oxfmt --check src/"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@size-limit/file": "^12.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "happy-dom": "^20.8.4",
    "nanostores": "^1.2.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.56.0",
    "publint": "^0.3.18",
    "size-limit": "^12.0.1",
    "tsdown": "0.21.4",
    "typescript": "^5.9.3",
    "valibot": "^1.3.1",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "nanostores": "^1.1.1"
  },
  "size-limit": [
    {
      "path": ".size-check/index.mjs",
      "limit": "2418 B"
    },
    {
      "path": ".size-check/render.mjs",
      "limit": "417 B"
    },
    {
      "path": ".size-check/context.mjs",
      "limit": "402 B"
    }
  ]
}
