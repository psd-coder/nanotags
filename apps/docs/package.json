{
  "name": "nanotags-docs",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter nanotags dev & astro dev",
    "build": "pnpm --filter nanotags build && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "pnpm --filter nanotags build && cmk && astro check",
    "lint": "pnpm run /^lint:/",
    "lint:styles": "stylelint \"src/**/*.css\"",
    "format": "pnpm run /^format:/",
    "format:styles": "stylelint \"src/**/*.css\" --fix"
  },
  "dependencies": {
    "@nanostores/persistent": "^1.3.3",
    "astro": "^6.0.8",
    "astro-pigment": "^0.11.1",
    "es-toolkit": "^1.45.1",
    "linkedom": "^0.18.12",
    "nanoid": "^5.1.7",
    "nanostores": "^1.2.0",
    "nanotags": "workspace:*",
    "sharp": "^0.34.0",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/ts-plugin": "^1.10.7",
    "@css-modules-kit/codegen": "^0.10.0",
    "@css-modules-kit/ts-plugin": "^0.10.0",
    "@types/node": "^24.12.0",
    "stylelint": "^17.5.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^5.9.3"
  }
}
