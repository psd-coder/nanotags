---
import { getCollection } from "astro:content";
import MainLayout from "~/layouts/MainLayout.astro";
import styles from './styles.module.css';
import { getHref } from "~/utils/urls";

const examples = await getCollection("examples");
---

<MainLayout title="Examples">
  <h1>Examples</h1>
  <p class={styles.subtitle}>Live playground — edit code and see changes in the Preview immediately.</p>
  <div class={styles.grid}>
    {examples.map((example) => (
      <div class={styles.card}>
        <h2 class={styles.cardTitle}>
          <a class={styles.cardLink} href={getHref(`examples/${example.id}`)}>{example.data.title}</a>
        </h2>
        <p class={styles.cardDescription} set:html={example.data.description} />
      </div>
    ))}
  </div>
</MainLayout>
