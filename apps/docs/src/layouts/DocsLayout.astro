---
import { Layout } from "~/components/Layout";
import { Icon } from "~/components/Icon";
import { MobileTableOfContents, TableOfContents } from "~/components/TableOfContents";
import PrevNextNav from "~/components/PrevNextNav/PrevNextNav.astro";
import type { NavLink } from "~/components/PrevNextNav/PrevNextNav.astro";
import { getHref } from "~/utils/urls";
import styles from "./styles.module.css";

type Heading = {
  depth: number;
  slug: string;
  text: string;
};

type Props = {
  title: string;
  slug: string;
  headings: Heading[];
  prev?: NavLink;
  next?: NavLink;
};

const { title, slug, headings, prev, next } = Astro.props;
---

<Layout title={title}>
  {headings.length > 0 && (
    <TableOfContents
      slot="sidebar"
      headings={headings}
      itemsSelector="[data-docs-content] :is(h2, h3)[id]"
    />
  )}
  <MobileTableOfContents headings={headings} />
  <article class="prose" data-docs-content>
    <div class={styles.headingRow}>
      <h1>{title}</h1>
      <a
        href={getHref(`${slug}.md`)}
        target="_blank"
        rel="noreferrer"
        class={styles.mdLink}
        aria-label="View as Markdown"
      >
        <Icon name="markdown" size={32} />
      </a>
    </div>
    <slot />
    <PrevNextNav prev={prev} next={next} />
  </article>
</Layout>
