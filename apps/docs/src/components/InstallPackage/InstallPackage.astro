---
import { CodePanels, codePanelsStyles } from "~/components/CodePanels";

type Props = {
  pkg: string;
  dev?: boolean;
};

const { pkg, dev } = Astro.props;

const managers = [
  { id: "pnpm", content: `pnpm add${dev ? " -D" : ""} ${pkg}` },
  { id: "npm", content: `npm install${dev ? " --save-dev" : ""} ${pkg}` },
  { id: "yarn", content: `yarn add${dev ? " -D" : ""} ${pkg}` },
  { id: "bun", content: `bun add${dev ? " -d" : ""} ${pkg}` },
];
---

<x-install-package class={codePanelsStyles.wrapper}>
  <CodePanels items={managers} defaultValue="pnpm" lang="shellscript" />
</x-install-package>
<script>
  import { defineCodePanels } from "~/utils/defineCodePanels";
  import { $pkgManager } from "~/stores/pkgManager";

  defineCodePanels("x-install-package", $pkgManager);
</script>
