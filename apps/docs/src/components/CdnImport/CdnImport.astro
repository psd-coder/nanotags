---
import { CodePanels, codePanelsStyles } from "astro-pigment/components/playground";
import { version } from "../../../../../packages/nanotags/package.json";

const cdns = [
  {
    id: "esm.sh",
    content: [
      `<script type="importmap">`,
      `{`,
      `  "imports": {`,
      `    "nanotags": "https://esm.sh/nanotags@${version}",`,
      `    "nanostores": "https://esm.sh/nanostores@1"`,
      `  }`,
      `}`,
      `</script>`,
    ].join("\n"),
  },
  {
    id: "jsdelivr",
    content: [
      `<script type="importmap">`,
      `{`,
      `  "imports": {`,
      `    "nanotags": "https://cdn.jsdelivr.net/npm/nanotags@${version}/+esm",`,
      `    "nanostores": "https://cdn.jsdelivr.net/npm/nanostores@1.2/+esm"`,
      `  }`,
      `}`,
      `</script>`,
    ].join("\n"),
  },
];
---

<x-cdn-import class={codePanelsStyles.wrapper}>
  <CodePanels items={cdns} defaultValue="esm.sh" lang="html" />
</x-cdn-import>
<script>
  import { persistentAtom } from "@nanostores/persistent";
  import { defineCodePanels } from "astro-pigment/utils/defineCodePanels";

  type Cdn = "esm.sh" | "jsdelivr";
  const $cdn = persistentAtom<Cdn>("cdn", "esm.sh");

  defineCodePanels("x-cdn-import", $cdn);
</script>
