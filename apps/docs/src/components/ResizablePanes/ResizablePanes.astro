---
import styles from "./styles.module.css";

type Props = {
  class?: string;
  direction: "horizontal" | "vertical"
}

const { class: className, direction } = Astro.props;
---
<x-resizable-panes direction={direction} class:list={[styles.container, className]}>
  <slot />
</x-resizable-panes>
<script>
  import { define } from "nano-wc";
  import { attachResizing } from "../../attachments/attachResizing";
  import { invariant } from "../../utils/invariant";

  define("x-resizable-panes")
    .withProps((p) => ({
      direction: p.oneOf(["horizontal", "vertical"]),
      minSize: p.number(5),
      maxSize: p.number(95),
    }))
    .withRefs((r) => ({
      panes: r.many("div"),
    }))
    .setup((ctx) => {
      invariant(ctx.refs.panes.length === 2, "ResizablePanes support exactly 2 panes");

      const startPane = ctx.refs.panes[0]!;
      let startBasis = 0;
      let containerSize = 0;

      function clampPercent(percent: number) {
        const min = ctx.props.$minSize.get();
        const max = ctx.props.$maxSize.get();
        return Math.min(max, Math.max(min, percent));
      }

      const { handle, setAriaValue } = attachResizing(ctx, {
        position: "after",
        element: startPane,
        direction: ctx.props.$direction.get(),
        label: "Resize panes",
        minValue: ctx.props.$minSize.get(),
        maxValue: ctx.props.$maxSize.get(),
        step: 2,
        onDragStart(info) {
          startBasis = info.elementSize;
          containerSize = info.containerSize;
        },
        onDrag(delta) {
          const percent = clampPercent(((startBasis + delta) / containerSize) * 100);
          startPane.style.flexBasis = `${percent}%`;
          setAriaValue(percent);
        },
        onKeyResize(value) {
          startPane.style.flexBasis = `${value}%`;
        },
      });

      ctx.effect(ctx.props.$direction, (direction) => {
        handle.dataset["direction"] = direction;
      });
    });
</script>
