{
  "name": "nanowc",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsgo --noEmit",
    "lint": "pnpm run /^lint:/",
    "lint:oxlint": "oxlint .",
    "lint:types": "tsgo --noEmit",
    "lint:size": "pnpm run build && size-limit",
    "format": "pnpm run /^format:/",
    "format:oxlint": "oxlint --fix --fix-suggestions .",
    "format:oxfmt": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "valibot": "^1.2.0"
  },
  "peerDependencies": {
    "nanostores": "^1.1.1"
  },
  "devDependencies": {
    "@size-limit/file": "^12.0.0",
    "@typescript/native-preview": "^7.0.0-dev",
    "@vitest/coverage-v8": "^4.0.18",
    "happy-dom": "^20.7.0",
    "nano-staged": "^0.9.0",
    "nanostores": "^1.1.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.0.0",
    "tsdown": "0.21.0-beta.2",
    "vitest": "^4.0.18"
  },
  "simple-git-hooks": {
    "pre-commit": "npx nano-staged"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "2825 B"
    }
  ],
  "nano-staged": {
    "*.{ts,tsx}": [
      "oxlint",
      "oxfmt"
    ]
  }
}
